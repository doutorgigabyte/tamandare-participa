# =============================================================================
# Tamandaré Participa — variáveis de ambiente
# =============================================================================
# Copie este arquivo pra .env.local e preencha com os valores reais.
# NUNCA commite .env.local — está no .gitignore.
# Conforme §10 do adendo v1.1.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Maps Platform — frontend (NEXT_PUBLIC_*, exposto ao browser)
# -----------------------------------------------------------------------------

# Chave pra Maps JavaScript API + Places Autocomplete (New).
# Restringir no Cloud Console por HTTP referrer: *.tamandareparticipa.com.br/*
NEXT_PUBLIC_GMAPS_FRONTEND_KEY=AIza-REPLACE-ME

# Map ID customizado (criar no Cloud Console > Maps Platform > Map Styles).
# Estilo dark monochrome conforme §5.3 do adendo v1.1.
NEXT_PUBLIC_GMAPS_MAP_ID=tamandare-dark-v1

# reCAPTCHA Enterprise — site key (pública).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc-REPLACE-ME

# -----------------------------------------------------------------------------
# Google Cloud — server only (NUNCA expor ao browser)
# -----------------------------------------------------------------------------

# Chave pra Geocoding, Elevation, Street View, Static Maps, Geolocation.
# Restringir no Cloud Console por IP (whitelist da Vercel).
GMAPS_BACKEND_KEY=AIza-REPLACE-ME

# Credenciais do service account com escopo de Speech-to-Text + Vision + Earth Engine.
# JSON inteiro numa linha só (ou base64 — adaptar o loader em lib/).
GCP_AI_CREDENTIALS={"type":"service_account","project_id":"REPLACE-ME","private_key_id":"REPLACE-ME","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE-ME\n-----END PRIVATE KEY-----\n","client_email":"REPLACE-ME@REPLACE-ME.iam.gserviceaccount.com","client_id":"REPLACE-ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Gemini API (text-embedding-004 + gemini-2.5-flash) — pode usar a mesma key do AI Studio.
GEMINI_API_KEY=AIza-REPLACE-ME

# reCAPTCHA Enterprise — secret key.
# Quando ausente, lib/recaptcha/verify.ts retorna { score:1, valid:true } pra
# permitir desenvolvimento local sem captcha. Em prod, sempre preencher.
RECAPTCHA_SECRET_KEY=6Lc-REPLACE-ME

# Project ID do Google Cloud onde a chave reCAPTCHA Enterprise foi criada.
# Necessário pra montar a URL do Assessment API (v1).
RECAPTCHA_PROJECT_ID=REPLACE-ME

# Salt do hash de CPF (sha256(salt|cpf)). Obrigatório se aplicação coletar CPF.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPF_HASH_SALT=REPLACE-ME-LONG-RANDOM-STRING

# Token do admin (/admin). Sem isso, painel de moderação fica desativado.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=REPLACE-ME-LONG-RANDOM-STRING

# Earth Engine — private key (geralmente igual a GCP_AI_CREDENTIALS, mas o adendo v1.1 §10 lista separado).
# Pode reutilizar o JSON do service account; está aqui pra documentação.
EARTH_ENGINE_PRIVATE_KEY=REPLACE-ME-OR-REUSE-GCP_AI_CREDENTIALS

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# URL pública do projeto (encontre em Supabase Dashboard > Settings > API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — segura pra expor (usada por usuários autenticados via RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-REPLACE-ME

# Service role key — bypassa RLS. SERVER ONLY. Usar só em route handlers e Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=eyJ-REPLACE-ME

# -----------------------------------------------------------------------------
# PostHog (analytics LGPD-friendly)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE-ME
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server-side ingest (para eventos a partir de Edge Functions).
POSTHOG_API_KEY=phc_REPLACE-ME

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------

# URL pública do app (usada em metadata, og:image, e-mails).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Data limite de contribuição (ISO 8601, BRT). Usado pelo countdown.
NEXT_PUBLIC_CONTRIBUTION_DEADLINE=2026-05-31T23:59:59-03:00

# -----------------------------------------------------------------------------
# API Gateway Dr GB (proxy unificado pra LLM/Maps/Voice)
# -----------------------------------------------------------------------------
# Centraliza chamadas a Gemini, Google Maps, AssemblyAI atrás de um único token.
# Padrão fast-path + fallback transparente: se Gateway falhar, app cai pro SDK direto.
# Ver lib/gateway/client.ts.

# URL base do Gateway (pode mudar conforme deploy).
DRGB_GATEWAY_URL=http://nylgaos7wzl2b193jwqgu53j.185.100.215.206.sslip.io

# Token do projeto "Tamandaré Participa" — obter no dashboard Dr GB ou via admin API.
# Formato: giga_<32 chars>. NUNCA commitar.
DRGB_GATEWAY_TOKEN=giga_REPLACE-ME

# Toggle: 'true' liga o fast-path. Em 'false', tudo vai direto pelos SDKs.
DRGB_GATEWAY_ENABLED=true

# Opcionais.
DRGB_GATEWAY_TIMEOUT_MS=60000
DRGB_GATEWAY_RETRIES=2
